ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ReactAmwalPayExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
 
  post_install do |installer|

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # React Native 0.79.x is not compatible with Xcode 26 / iOS 26 SDK.
    # Patch ALL pod targets to use c++17 and disable -Werror so the build succeeds.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |cfg|
        cfg.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        cfg.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        cfg.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'

        # Strip hardcoded -std=c++20 and -Werror from OTHER_CPLUSPLUSFLAGS
        flags = cfg.build_settings['OTHER_CPLUSPLUSFLAGS']
        if flags
          flags = [flags].flatten.join(' ')
          flags = flags.gsub('-std=c++20', '-std=c++17').gsub(/\s*-Werror\b/, '')
          cfg.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags
        end

        # Also patch OTHER_CFLAGS
        cflags = cfg.build_settings['OTHER_CFLAGS']
        if cflags
          cflags = [cflags].flatten.join(' ')
          cflags = cflags.gsub(/\s*-Werror\b/, '')
          cfg.build_settings['OTHER_CFLAGS'] = cflags
        end
      end

      # Set "Build Libraries for Distribution" to NO for amwalsdk and exclude x86_64
      if target.name == 'amwalsdk'
        target.build_configurations.each do |cfg|
          cfg.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
          cfg.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'x86_64'
        end
      end
    end

    # Also patch xcconfig files for pods that hardcode flags (e.g. Yoga, fmt)
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', '**', '*.xcconfig')).each do |xcconfig_path|
      content = File.read(xcconfig_path)
      changed = false
      new_content = content
        .gsub('-std=c++20') { changed = true; '-std=c++17' }
        .gsub(/ -Werror(?![=\w])/) { changed = true; '' }
      File.write(xcconfig_path, new_content) if changed
    end

  end
end