ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ReactAmwalPayExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
 
  post_install do |installer|
    # ── Xcode 26 / Clang 26 fix for fmt ────────────────────────────────
    # CRITICAL: Must be set BEFORE react_native_post_install runs
    # Xcode 26 tightened consteval enforcement in C++20. The fmt pod vendored
    # inside React Native uses a consteval pattern that no longer compiles.
    # Scoping fmt to C++17 skips the consteval path without affecting the
    # rest of the project which legitimately needs C++20.
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |cfg|
          cfg.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          cfg.build_settings['GCC_C_LANGUAGE_STANDARD'] = 'c17'
          # Add compiler flags to suppress consteval errors as additional safety
          cfg.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
          cfg.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-Wno-error=consteval'
          cfg.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-Wno-consteval'
        end
      end
    end

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |cfg|
        # Disable warnings-as-errors to avoid noisy build failures
        cfg.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        cfg.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'

        # ── Size optimizations (release only) ──────────────────────────────
        if cfg.name == 'Release'
          # Strip dead code and symbols
          cfg.build_settings['DEAD_CODE_STRIPPING']              = 'YES'
          cfg.build_settings['STRIP_INSTALLED_PRODUCT']          = 'YES'
          cfg.build_settings['STRIP_STYLE']                      = 'all'
          cfg.build_settings['COPY_PHASE_STRIP']                 = 'YES'

          # Compiler optimizations
          cfg.build_settings['GCC_OPTIMIZATION_LEVEL']           = 's'   # optimize for size
          cfg.build_settings['SWIFT_OPTIMIZATION_LEVEL']         = '-Osize'

          # Remove debug symbols from the binary (dSYM is kept separately)
          cfg.build_settings['DEBUG_INFORMATION_FORMAT']         = 'dwarf-with-dsym'
          cfg.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS']   = 'NO'

          # Enable Link-Time Optimization for cross-module dead-code elimination
          cfg.build_settings['LLVM_LTO']                         = 'YES'
        end
      end

      # Re-apply fmt C++17 fix AFTER react_native_post_install to ensure it sticks
      if target.name == 'fmt'
        target.build_configurations.each do |cfg|
          cfg.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          cfg.build_settings['GCC_C_LANGUAGE_STANDARD'] = 'c17'
          # Add compiler flags to suppress consteval errors as additional safety
          cfg.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
          cfg.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-Wno-error=consteval'
          cfg.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-Wno-consteval'
        end
      end

      # Set "Build Libraries for Distribution" to NO for amwalsdk and exclude x86_64
      if target.name == 'amwalsdk'
        target.build_configurations.each do |cfg|
          cfg.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
          cfg.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'x86_64'
        end
      end
    end

  end
end